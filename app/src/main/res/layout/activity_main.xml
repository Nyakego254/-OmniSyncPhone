<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#1a1a2e">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OmniSync Phone"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#ffffff"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Permissions Required"
        android:textSize="18sp"
        android:textColor="#ffffff"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:id="@+id/permissionPhoneState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#16213e"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📞 Phone State"
            android:textColor="#ffffff"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/statusPhoneState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textColor="#ffa500"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/permissionCallLog"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#16213e"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 Call Log"
            android:textColor="#ffffff"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/statusCallLog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textColor="#ffa500"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/permissionSms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#16213e"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="💬 SMS"
            android:textColor="#ffffff"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/statusSms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textColor="#ffa500"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/permissionNotification"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#16213e"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔔 Notification Access"
            android:textColor="#ffffff"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/statusNotification"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textColor="#ffa500"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/permissionBattery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#16213e"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔋 Battery Optimization"
            android:textColor="#ffffff"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/statusBattery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textColor="#ffa500"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/permissionAutostart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#16213e"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🚀 Auto-start"
            android:textColor="#ffffff"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/statusAutostart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pending"
            android:textColor="#ffa500"
            android:textSize="14sp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnRequestPermissions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Grant Permissions"
        android:textColor="#ffffff"
        android:backgroundTint="#0f3460"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnOpenSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Open System Settings"
        android:textColor="#ffffff"
        android:backgroundTint="#16213e" />

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Sync Status: Initializing..."
        android:textColor="#888888"
        android:textSize="12sp"
        android:gravity="center" />

</LinearLayout>